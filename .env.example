# =============================================================================
# Cognito バッチ登録バックエンド 環境変数設定
#
# 使い方:
#   cp .env.example .env
#   .env を編集して実際の値を入力する (.env は .gitignore 済みで git に含まれない)
# =============================================================================


# -----------------------------------------------------------------------------
# 動作モード
# -----------------------------------------------------------------------------

# Cognito の動作モードを選択する
#   mock       : ローカル開発用モック (AWS 不要、デフォルト)
#   aws-import : 実際の AWS Cognito User Import Job API を使う
COGNITO_MODE=mock


# -----------------------------------------------------------------------------
# AWS 認証情報 (COGNITO_MODE=aws-import または実際の S3 を使う場合に必須)
# -----------------------------------------------------------------------------

# IAM ユーザーまたはロールのアクセスキー ID
AWS_ACCESS_KEY_ID=

# IAM ユーザーまたはロールのシークレットアクセスキー
AWS_SECRET_ACCESS_KEY=

# 一時認証情報 (STS) のセッショントークン
# AWS SSO / assume-role / CloudShell などで取得した一時認証情報を使う場合に必須
# 通常の IAM ユーザー (AKIA... のキー) では不要
AWS_SESSION_TOKEN=


# -----------------------------------------------------------------------------
# AWS Cognito 設定 (COGNITO_MODE=aws-import の場合に必須)
# -----------------------------------------------------------------------------

# Cognito User Pool が存在するリージョン (例: ap-northeast-1)
COGNITO_REGION=

# Cognito User Pool ID (例: ap-northeast-1_xxxxxxxxx)
COGNITO_USER_POOL_ID=

# Cognito が CloudWatch Logs に書き込む際に引き受ける IAM ロールの ARN
# 例: arn:aws:iam::123456789012:role/CognitoCloudWatchLogsRole
COGNITO_CLOUDWATCH_LOGS_ROLE_ARN=


# -----------------------------------------------------------------------------
# S3 設定
# -----------------------------------------------------------------------------

# S3 エンドポイント URL
#   ローカル (Garage)  : http://s3:3900  (docker-compose ネットワーク内のサービス名)
#   実際の AWS S3      : 空欄のまま (SDK がデフォルトエンドポイントを使用)
S3_ENDPOINT=http://s3:3900

# S3 バケットが存在するリージョン
#   ローカル (Garage)  : garage  (任意の文字列で OK)
#   実際の AWS S3      : 例) ap-northeast-1
S3_REGION=garage

# CSV ファイルを格納する S3 バケット名
S3_BUCKET=cognito-csv

# バケット内でオブジェクトキーに付けるプレフィックス (末尾スラッシュ不要)
S3_KEY_PREFIX=batch-jobs

# S3 認証情報ファイルのパス (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY が未設定の場合に参照)
# docker-compose では ./apps/s3/credentials.env をコンテナ内 /s3-config にマウントしている
S3_CREDENTIALS_FILE=/s3-config/credentials.env


# -----------------------------------------------------------------------------
# ジョブ処理タイミング調整
# -----------------------------------------------------------------------------

# Cognito インポートジョブのステータスをポーリングする間隔 (ミリ秒)
COGNITO_IMPORT_POLL_INTERVAL_MS=2000

# バッチ処理の各ステップ間の待機時間 (ミリ秒、モック使用時の疑似遅延にも使われる)
JOB_STEP_DELAY_MS=1500
